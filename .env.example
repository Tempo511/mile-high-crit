# Online multiplayer (rung 3) rides Supabase Realtime broadcast channels.
# 1. Create a free project at https://supabase.com
# 2. Project Settings -> API: copy the URL and the anon/public key
# 3. Save this file as .env.local with the real values (gitignored)
# The anon key is safe to ship in a client build - that's what it's for.
VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
